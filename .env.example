# Pinata IPFS — used by the Launch Token image upload.
# Create a JWT at https://app.pinata.cloud (API Keys → New Key, with pinFileToIPFS).
# Copy this file to `.env` and fill it in for local dev. For the deployed site,
# set the same values as GitHub Actions secrets PINATA_JWT / PINATA_GATEWAY.
VITE_PINATA_JWT=
# Optional: your dedicated Pinata gateway, e.g. https://your-name.mypinata.cloud
# Defaults to https://gateway.pinata.cloud if unset.
VITE_PINATA_GATEWAY=
